PORT=3000

# Zulip bot credentials (from zuliprc)
ZULIP_REALM=https://atfedi.de
ZULIP_USERNAME=web-chat-bot@atfedi.de
ZULIP_API_KEY=

# Stream the bot will post into; topics = one per visitor session
ZULIP_STREAM=web-相談

# Optional: custom emoji prefix on visitor messages (e.g. :neocat__w:)
ZULIP_VISITOR_EMOJI=:neocat__w:

# Discord (joinfediverse.kr 用)。設定しなければ Discord adapter は登録されない
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PARENT_CHANNEL_ID=
DISCORD_WEBHOOK_URL=
