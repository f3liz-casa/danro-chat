{
  "name": "danro-talk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "typecheck": "tsc --noEmit && tsc -p widget/tsconfig.json --noEmit",
    "build:widget": "esbuild widget/chat-widget.ts --bundle --format=esm --outfile=widget/chat-widget.js",
    "dev:widget": "esbuild widget/chat-widget.ts --bundle --format=esm --outfile=widget/chat-widget.js --watch --servedir=widget"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "nanoid": "^5.0.7",
    "ws": "^8.18.0",
    "zulip-js": "^2.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
