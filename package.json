{
  "name": "danro-talk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "predeploy": "npm run build:widget && node scripts/gen-widget-text.mjs",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p widget/tsconfig.json --noEmit",
    "build:widget": "esbuild widget/chat-widget.ts --bundle --format=esm --outfile=widget/chat-widget.js",
    "dev:widget": "esbuild widget/chat-widget.ts --bundle --format=esm --outfile=widget/chat-widget.js --watch --servedir=widget"
  },
  "dependencies": {
    "@twemoji/api": "^17.0.2",
    "nanoid": "^5.0.7",
    "resend": "^6.12.3",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.0.0"
  }
}
